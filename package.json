{
  "name": "use-right-click",
  "version": "0.1.0",
  "description": "React hook for custom context menus with desktop right-click and mobile long-press support",
  "keywords": [
    "react",
    "hook",
    "context-menu",
    "right-click",
    "long-press",
    "touch",
    "mobile"
  ],
  "author": "piro0919",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piro0919/use-right-click.git"
  },
  "homepage": "https://github.com/piro0919/use-right-click#readme",
  "bugs": {
    "url": "https://github.com/piro0919/use-right-click/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "next build",
    "build:lib": "tsup",
    "dev": "next dev",
    "format": "biome format --write",
    "lint": "biome check",
    "prepublishOnly": "npm run build:lib",
    "start": "next start"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "dependencies": {
    "use-long-press": "3.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "usehooks-ts": "^3.1.1"
  }
}
